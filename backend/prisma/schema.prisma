generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Search {
  id              Int      @id @default(autoincrement())
  keyword         String
  country         String
  resultsSnapshot Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([keyword, country], name: "keyword_country")
}