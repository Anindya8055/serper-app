generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Search {
  id              Int      @id @default(autoincrement())
  keyword         String
  country         String
  resultsSnapshot Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([keyword, country], name: "keyword_country")
}

model SiteAnalysis {
  id                Int      @id @default(autoincrement())
  url               String   @unique
  domain            String
  homepageUrl       String?
  classifierVersion String
  fetchMethod       String?
  siteType          String?
  contentType       String?
  confidence        String?
  topScore          Float?
  secondScore       Float?
  scoreGap          Float?
  needsReview       Boolean  @default(false)

  pageSignals       Json
  pageResults       Json?
  scores            Json?
  matchedSignals    Json?
  pageClassifications Json?
  analyzedPages     Json?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([domain])
  @@index([classifierVersion])
  @@index([siteType])
  @@index([contentType])
  @@index([confidence])
}